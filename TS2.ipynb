    "\n",
    "n = np.random.normal(mu, sigma, nn)\n",
    "\n",
    "señal_con_ruido = s + n\n",
    "\n",
    "\n",
    "plt.figure()\n",
    "plt.plot(tt,señal_con_ruido, label = \"señal con ruido\")\n",
