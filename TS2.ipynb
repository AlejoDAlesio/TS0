   ],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "\n",
    "def mi_funcion_sen(vmax, dc, fs, ph, nn, fm):\n",
    "\n",
    "    tt = np.arange(nn) / fm \n",
    "    s = dc + vmax * np.sin(2 * np.pi * fs * tt + ph)\n",
    "\n",
    "    return tt, s\n",
    "\n",
    "vmax = 1\n",
    "dc = 0\n",
    "ph = 0\n",
    "nn = 1000\n",
    "fm = 1000 \n",
    "fs = fm/nn \n",
    "tt, s = mi_funcion_sen(vmax, dc, fs, ph, nn, fm)\n",
    "\n",
    "#%% # Ruido y potencia\n",
    "\n",
    "mu = 0\n",
    "nn = 1000\n",
    "vmax=1\n",
    "\n",
